{% if has_plugin.get("postgres") -%}
POSTGRES_DB={{ values.get('postgres', {}).get('db', 'app_db') }}
POSTGRES_PORT={{ values.get('postgres', {}).get('port', 5432) }}
{% endif -%}
{% if has_plugin.get("redis") -%}
REDIS_PORT={{ values.get('redis', {}).get('port', 6379) }}
{% endif -%}
{% if has_plugin.get("jupyter") -%}
JUPYTER_PORT={{ values.get('jupyter', {}).get('port', 8888) }}
{% endif -%}
{% if has_plugin.get("voila") -%}
VOILA_PORT={{ values.get('voila', {}).get('port', 8866) }}
{% endif -%}